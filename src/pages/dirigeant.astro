---
import SiteLayout from '../layouts/SiteLayout.astro';
import Container from '../components/layout/Container.astro';
import PrimaryCta from '../components/ui/PrimaryCta.astro';
import Reveal from '../components/ui/Reveal.astro';
import { FORFAIT_MAX_DAYS, RDV_DURATION_LABEL, TJM_DISPLAY } from '../lib/site.const';

const benefits = [
  {
    title: 'On parle business avant de parler tech',
    description:
      "Je traduis vos enjeux en choix techniques, pas l'inverse. Vous n'avez pas à apprendre ce qu'est une API pour prendre une décision éclairée — c'est mon rôle de vous donner les éléments qui comptent.",
  },
  {
    title: 'Pas de jargon inutile',
    description:
      "Les comptes-rendus quotidiens sont rédigés pour être lisibles sans bagage technique. Vous savez ce qui a été fait, ce qui bloque, et ce que j'attends de vous — sans avoir à décrypter.",
  },
  {
    title: 'Un engagement sur la livraison',
    description:
      'Je ne livre pas de maquettes ou de specs sans suite. Je livre du produit fonctionnel, déployé, utilisable. Si un délai change, vous le savez le jour même — pas à la livraison.',
  },
  {
    title: 'Un démarrage sans risque long terme',
    description: `Le démarrage se fait sur devis borné, jusqu'à ${FORFAIT_MAX_DAYS} jours. Vous testez la collaboration avant de vous engager sur la durée. Si ça colle, on continue en régie à ${TJM_DISPLAY}.`,
  },
];

const journey = [
  {
    title: 'Un premier échange sur votre projet',
    duration: RDV_DURATION_LABEL,
    description:
      "On parle de votre contexte, de votre marché, de ce que vous voulez construire et pourquoi. Pas besoin de savoir ce que vous voulez techniquement — c'est ce que je suis là pour comprendre.",
  },
  {
    title: 'Une traduction business → tech',
    duration: 'Sous 5 jours ouvrés',
    description:
      'Si on est aligné, je formalise ce que ça implique techniquement : scope, architecture, jalons, estimation. En français, sans jargon superflu. Vous arbitrez les compromis avec les bons éléments en main.',
  },
  {
    title: 'Un démarrage borné',
    duration: `Jusqu'à ${FORFAIT_MAX_DAYS} jours`,
    description:
      'On commence par un devis à durée limitée. Vous voyez comment je travaille, vous recevez un compte-rendu chaque soir, vous avez la main sur les priorités. Aucune surprise en fin de sprint.',
  },
  {
    title: 'La suite, en régie',
    duration: TJM_DISPLAY,
    description:
      'Si la collaboration est satisfaisante des deux côtés, on continue pour faire vivre et évoluer le produit. Tarif transparent, reporting constant, pas de tunnel de développement opaque.',
  },
];

const faqs = [
  {
    question: "Je ne connais rien à la tech — est-ce que c'est un problème ?",
    answer:
      "Non. Ce n'est pas votre métier, c'est le mien. Ce que j'attends de vous, c'est que vous connaissiez votre marché, vos utilisateurs, vos contraintes business. Je m'occupe de traduire ça en produit. Si une décision technique vous concerne, je vous l'explique en termes clairs avant de la prendre.",
  },
  {
    question: `Un MVP en ${FORFAIT_MAX_DAYS} jours, c'est réaliste ?`,
    answer:
      "Oui, si le scope est bien défini. C'est pour ça qu'on commence par un cadrage sérieux. Un MVP, ce n'est pas un produit fini — c'est le minimum fonctionnel qui permet de tester une hypothèse. Si votre hypothèse est claire, le périmètre se délimite. Si elle ne l'est pas encore, c'est ce qu'on clarifie ensemble avant de signer.",
  },
  {
    question: "Vous pouvez me conseiller sur les choix de stack ou d'architecture ?",
    answer:
      "Oui, c'est même une partie importante de ce que je fais. Pas pour vous vendre une techno exotique, mais pour vous aider à choisir ce qui correspond à votre contexte : votre budget, vos ambitions, vos contraintes de recrutement futur. Je vous donne mon avis avec les raisons, vous décidez.",
  },
  {
    question: "Vous pouvez m'aider à recruter mon équipe tech ?",
    answer:
      "En partie. Je ne chasse pas les profils — c'est le travail d'un recruteur. Mais je peux créer les tests techniques, évaluer les candidats, et conduire les entretiens techniques. C'est un rôle que j'ai tenu chez Coton pour recruter les freelances du collectif, et qu'on proposait aussi à nos clients. Si vous avez des candidats à évaluer, je vous donne une lecture structurée.",
  },
];
---

<SiteLayout
  title="Développement produit pour dirigeants"
  description="Vous avez un projet tech à démarrer ou à accélérer. Vous voulez un dev senior qui parle business, livre avec rigueur, et vous tient informé chaque jour. Premier échange gratuit en 30 à 45 minutes."
  canonicalPath="/dirigeant"
>
  <!-- HERO -->
  <section class="pt-16 pb-[var(--space-section-tight)] md:pt-24">
    <Container size="wide">
      <Reveal>
        <p class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-primary-600)]">
          Pour les dirigeants
        </p>
        <h1
          class="mt-5 max-w-[24ch] text-[length:var(--text-display)] font-semibold leading-[0.98] tracking-[-0.03em] text-[var(--color-text)]"
        >
          Vous avez un projet tech.
          <span class="block text-[var(--color-primary-700)]"
            >Il faut quelqu'un qui parle business.</span
          >
        </h1>
        <p
          class="mt-10 max-w-[55ch] text-[length:var(--text-xl)] leading-[var(--leading-snug)] text-[var(--color-text-muted)] tracking-[-0.005em]"
        >
          Vous dirigez une boîte. Vous avez une idée de produit, une fonctionnalité à ajouter, ou
          une refonte à mener. Vous ne cherchez pas à comprendre toute la technique — vous cherchez
          <strong>quelqu'un qui la maîtrise et vous tient informé.</strong>
        </p>
        <div class="mt-12 flex flex-wrap items-center gap-x-6 gap-y-4">
          <PrimaryCta size="lg" class="w-full sm:w-auto" />
          <a
            href="/methode"
            class="group inline-flex items-center gap-2 text-base font-medium text-[var(--color-text)] tracking-[-0.005em]"
          >
            Voir ma méthode
            <span
              class="inline-block h-px w-8 bg-[var(--color-text-subtle)] transition-[width,background-color] duration-[var(--duration-default)] [transition-timing-function:var(--ease-out-quart)] group-hover:w-12 group-hover:bg-[var(--color-primary-600)]"
            ></span>
          </a>
        </div>
      </Reveal>
    </Container>
  </section>

  <!-- BÉNÉFICES -->
  <section
    class="mt-[var(--space-section-tight)] py-[var(--space-section)] border-y border-[var(--color-border)] bg-[var(--color-bg-elevated)]"
  >
    <Container size="wide">
      <Reveal class="max-w-[52ch]">
        <p class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-primary-600)]">
          01 · Ce que vous obtenez
        </p>
        <h2
          class="mt-5 text-[length:var(--text-3xl)] font-semibold leading-[var(--leading-tight)] tracking-[-0.02em] text-[var(--color-text)]"
        >
          Quatre engagements concrets, pas des adjectifs.
        </h2>
      </Reveal>

      <dl class="mt-16 grid items-start gap-x-12 gap-y-12 md:grid-cols-2">
        {
          benefits.map((benefit, index) => (
            <Reveal as="div" delay={index * 70} class="flex flex-col gap-3">
              <dt class="flex items-baseline gap-3">
                <span class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-text-subtle)]">
                  {String(index + 1).padStart(2, '0')}
                </span>
                <span class="h-px flex-1 bg-[var(--color-border)]" aria-hidden="true" />
              </dt>
              <dd>
                <p class="text-[length:var(--text-xl)] font-semibold leading-[var(--leading-snug)] tracking-[-0.015em] text-[var(--color-text)]">
                  {benefit.title}
                </p>
                <p class="mt-3 max-w-[55ch] text-[length:var(--text-base)] leading-[var(--leading-relaxed)] text-[var(--color-text-muted)]">
                  {benefit.description}
                </p>
              </dd>
            </Reveal>
          ))
        }
      </dl>
    </Container>
  </section>

  <!-- DÉROULÉ -->
  <section class="py-[var(--space-section)]">
    <Container size="wide">
      <Reveal class="max-w-[100ch]">
        <p class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-primary-600)]">
          02 · Comment ça se passe
        </p>
        <h2
          class="mt-5 text-[length:var(--text-3xl)] font-semibold leading-[var(--leading-tight)] tracking-[-0.02em] text-[var(--color-text)]"
        >
          Quatre phases. <br />Sans engagement long terme avant qu'on ait travaillé ensemble.
        </h2>
      </Reveal>

      <ol class="mt-16 border-b border-[var(--color-border)]">
        {
          journey.map((step, index) => (
            <Reveal as="li" delay={index * 80}>
              <article class="flex flex-col gap-6 border-t border-[var(--color-border)] py-10 md:flex-row md:items-start md:gap-12 md:py-12">
                <div class="md:w-72 md:shrink-0">
                  <p class="font-mono text-5xl font-semibold leading-none tracking-[-0.04em] text-[var(--color-primary-700)] md:text-6xl">
                    {String(index + 1).padStart(2, '0')}
                  </p>
                  <p class="mt-4 font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-text-subtle)]">
                    {step.duration}
                  </p>
                </div>
                <div class="md:min-w-0 md:flex-1">
                  <h3 class="text-[length:var(--text-2xl)] font-semibold leading-[var(--leading-snug)] tracking-[-0.015em] text-[var(--color-text)]">
                    {step.title}
                  </h3>
                  <p class="mt-4 max-w-[65ch] text-[length:var(--text-base)] leading-[var(--leading-relaxed)] text-[var(--color-text-muted)]">
                    {step.description}
                  </p>
                </div>
              </article>
            </Reveal>
          ))
        }
      </ol>

      <Reveal class="mt-12">
        <a
          href="/methode"
          class="group inline-flex items-center gap-2 text-base font-medium text-[var(--color-text)] tracking-[-0.005em]"
        >
          Voir tous les détails de la méthode
          <span
            class="inline-block h-px w-8 bg-[var(--color-text-subtle)] transition-[width,background-color] duration-[var(--duration-default)] [transition-timing-function:var(--ease-out-quart)] group-hover:w-12 group-hover:bg-[var(--color-primary-600)]"
          ></span>
        </a>
      </Reveal>
    </Container>
  </section>

  <!-- FAQ COURTE -->
  <section
    class="py-[var(--space-section)] border-y border-[var(--color-border)] bg-[var(--color-bg-subtle)]"
  >
    <Container size="wide">
      <Reveal class="max-w-[52ch]">
        <p class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-primary-600)]">
          03 · Questions qui reviennent
        </p>
        <h2
          class="mt-5 text-[length:var(--text-3xl)] font-semibold leading-[var(--leading-tight)] tracking-[-0.02em] text-[var(--color-text)]"
        >
          Quatre questions qu'on me pose souvent.
        </h2>
      </Reveal>

      <div
        class="mt-16 divide-y divide-[var(--color-border)] border-y border-[var(--color-border)]"
      >
        {
          faqs.map((faq, index) => (
            <Reveal as="div" delay={index * 80}>
              <details class="faq-item group py-8 md:py-10">
                <summary class="faq-summary flex cursor-pointer items-start justify-between gap-6 list-none">
                  <h3 class="text-[length:var(--text-xl)] font-semibold leading-[var(--leading-snug)] tracking-[-0.01em] text-[var(--color-text)]">
                    {faq.question}
                  </h3>
                  <span
                    class="faq-icon mt-1 flex size-7 shrink-0 items-center justify-center rounded-full border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text-subtle)] transition-[transform,background-color,border-color,color] duration-[var(--duration-default)] [transition-timing-function:var(--ease-out-quart)]"
                    aria-hidden="true"
                  >
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                      <path
                        d="M6 2v8M2 6h8"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                      />
                    </svg>
                  </span>
                </summary>
                <p class="mt-5 max-w-[95ch] text-[length:var(--text-base)] leading-[var(--leading-relaxed)] text-[var(--color-text-muted)]">
                  {faq.answer}
                </p>
              </details>
            </Reveal>
          ))
        }
      </div>

      <Reveal class="mt-12">
        <a
          href="/faq"
          class="group inline-flex items-center gap-2 text-base font-medium text-[var(--color-text)] tracking-[-0.005em]"
        >
          Voir toutes les questions fréquentes
          <span
            class="inline-block h-px w-8 bg-[var(--color-text-subtle)] transition-[width,background-color] duration-[var(--duration-default)] [transition-timing-function:var(--ease-out-quart)] group-hover:w-12 group-hover:bg-[var(--color-primary-600)]"
          ></span>
        </a>
      </Reveal>
    </Container>
  </section>

  <!-- CTA FINALE -->
  <section
    class="relative overflow-hidden py-[var(--space-section)] bg-[var(--color-bg-deep)] text-[var(--color-text-inverse)]"
  >
    <div
      aria-hidden="true"
      class="pointer-events-none absolute -top-32 -right-32 size-[28rem] rounded-full opacity-30"
      style="background: radial-gradient(closest-side, oklch(50% 0.12 155 / 0.6), transparent);"
    >
    </div>

    <Container size="wide">
      <div class="grid gap-12 lg:grid-cols-12 lg:items-end">
        <Reveal class="lg:col-span-8">
          <p class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-primary-200)]">
            Premier échange · {RDV_DURATION_LABEL} · Sans engagement
          </p>
          <h2
            class="mt-5 text-[length:var(--text-5xl)] font-semibold leading-[0.98] tracking-[-0.03em]"
          >
            On parle de votre projet,
            <span class="block text-[var(--color-primary-200)]">en termes clairs.</span>
          </h2>
          <p
            class="mt-8 max-w-[55ch] text-[length:var(--text-lg)] leading-[var(--leading-relaxed)] text-[color-mix(in_oklab,var(--color-text-inverse)_75%,transparent)]"
          >
            Vous décrivez votre contexte business, vos objectifs, vos contraintes. Je vous dis ce
            que ça implique techniquement, ce qui est faisable, et comment on pourrait travailler
            ensemble.
          </p>
        </Reveal>
        <Reveal class="lg:col-span-4 lg:text-right" delay={150}>
          <PrimaryCta size="lg" class="w-full sm:w-auto" />
        </Reveal>
      </div>
    </Container>
  </section>
</SiteLayout>

<style>
  .faq-summary::-webkit-details-marker {
    display: none;
  }

  .faq-item[open] .faq-icon {
    transform: rotate(45deg);
    border-color: var(--color-primary-400);
    background: var(--color-primary-50);
    color: var(--color-primary-700);
  }

  .faq-summary:hover .faq-icon {
    border-color: var(--color-primary-400);
    color: var(--color-primary-700);
  }
</style>
