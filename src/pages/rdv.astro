---
import SiteLayout from '../layouts/SiteLayout.astro';
import Container from '../components/layout/Container.astro';
import Button from '../components/ui/Button.astro';
import { CAL_BOOKING_URL, RDV_DURATION_LABEL } from '../lib/site.const';

const repartAvec = [
  'Une lecture honnête de votre projet, dans son contexte.',
  'Les bonnes questions à se poser avant de coder.',
  'Trois directions concrètes pour avancer cette semaine.',
];
---

<SiteLayout
  title="Réserver un échange gratuit"
  description={`Un premier échange en ${RDV_DURATION_LABEL} pour parler de votre projet, sans engagement. Vous repartez avec une lecture honnête et des directions concrètes.`}
>
  <section class="py-[var(--space-section)]">
    <Container size="default">
      <div class="grid gap-16 md:grid-cols-12 md:items-start">
        <header class="md:col-span-5">
          <p
            class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-text-subtle)]"
          >
            Premier échange · {RDV_DURATION_LABEL} · Sans engagement
          </p>
          <h1
            class="mt-4 text-[length:var(--text-4xl)] font-semibold leading-[var(--leading-tight)] tracking-[-0.025em] text-[var(--color-text)]"
          >
            On parle de votre projet, <span class="text-[var(--color-primary-700)]"
              >gratuitement</span
            >.
          </h1>
          <p
            class="mt-6 text-[length:var(--text-lg)] leading-[var(--leading-relaxed)] text-[var(--color-text-muted)]"
          >
            Pas un appel découverte camouflé. Un vrai cadrage : vous arrivez avec votre contexte,
            je donne une lecture honnête, on regarde si on est aligné. Peu importe la suite.
          </p>
        </header>

        <div class="md:col-span-7">
          <p
            class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-primary-600)]"
          >
            Vous repartez avec
          </p>
          <ul class="mt-6 grid gap-5">
            {
              repartAvec.map((item, index) => (
                <li class="flex gap-4">
                  <span
                    class="flex size-7 shrink-0 items-center justify-center rounded-[var(--radius-pill)] bg-[var(--color-primary-100)] font-mono text-xs font-semibold text-[var(--color-primary-700)]"
                    aria-hidden="true"
                  >
                    {String(index + 1).padStart(2, '0')}
                  </span>
                  <p class="text-[length:var(--text-lg)] leading-[var(--leading-snug)] text-[var(--color-text)] tracking-[-0.005em]">
                    {item}
                  </p>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <div
        class="mt-20 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-8 md:p-12"
      >
        <p
          class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-text-subtle)]"
        >
          Choisir un créneau
        </p>
        <h2
          class="mt-4 text-[length:var(--text-2xl)] font-semibold leading-[var(--leading-tight)] tracking-[-0.015em] text-[var(--color-text)]"
        >
          Heures ouvrées, fuseau Paris.
        </h2>
        <p
          class="mt-4 max-w-[55ch] text-[length:var(--text-base)] leading-[var(--leading-relaxed)] text-[var(--color-text-muted)]"
        >
          L'intégration Cal.com sera embarquée ici. En attendant, voici le lien direct.
        </p>
        <div class="mt-8">
          <Button href={CAL_BOOKING_URL} variant="primary" size="lg" external class="w-full sm:w-auto">
            Ouvrir mon Cal.com
            <svg
              aria-hidden="true"
              width="14"
              height="14"
              viewBox="0 0 14 14"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M5 3h6v6" />
              <path d="M11 3 4 10" />
            </svg>
          </Button>
        </div>
      </div>

      <div class="mt-16 max-w-[60ch] text-[var(--color-text-muted)]">
        <p class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-text-subtle)]">
          Si on est aligné
        </p>
        <p class="mt-4 text-[length:var(--text-base)] leading-[var(--leading-relaxed)]">
          Devis sous 5 jours ouvrés, démarrage sur un cadre borné (jusqu'à 20 jours) puis régie pour
          la suite. Pas d'engagement long terme avant qu'on ait travaillé ensemble.
        </p>
      </div>
    </Container>
  </section>
</SiteLayout>
