---
import SiteLayout from '../layouts/SiteLayout.astro';
import Container from '../components/layout/Container.astro';
import PrimaryCta from '../components/ui/PrimaryCta.astro';
import Reveal from '../components/ui/Reveal.astro';
import { RDV_DURATION_LABEL, TJM_DISPLAY } from '../lib/site.const';

const benefits = [
  {
    title: 'Une intégration sans friction',
    description:
      "Je lis le code avant d'en écrire. Je comprends vos conventions avant de les modifier. Je pose des questions utiles, pas du bruit. Vous n'avez pas à m'expliquer comment fonctionne un PR.",
  },
  {
    title: 'Autonomie senior, sans délégation aveugle',
    description:
      "Je prends des décisions techniques sans vous solliciter toutes les demi-heures. Quand une décision dépasse mon périmètre ou engage l'architecture, je reviens vous chercher.",
  },
  {
    title: 'Un compte-rendu quotidien orienté tech',
    description:
      "Chaque jour travaillé, un message factuel : ce qui a été mergé, ce qui bloque, ce que j'ai arbitré et pourquoi, ce qui suit. Vous et votre équipe savez exactement ce qui a été touché.",
  },
  {
    title: 'En régie, transparent',
    description: `${TJM_DISPLAY}. Pas de sur-facturation cachée, pas de frais de "coordination". Vous payez ce que je fais, vous savez ce que je fais.`,
  },
];

const journey = [
  {
    title: 'Un premier échange technique',
    duration: RDV_DURATION_LABEL,
    description:
      'On parle de votre stack, de vos conventions, du chantier que vous avez en tête. Je vous pose les questions qui comptent. Vous repartez avec une idée claire de comment ça pourrait se passer.',
  },
  {
    title: 'Un audit rapide du contexte',
    duration: '1 à 2 jours',
    description:
      'Si on est aligné, je prends le temps de lire la codebase avant de démarrer. Pas de blind dive. Je reviens avec mes observations, mes questions, et une estimation du chantier ciblé.',
  },
  {
    title: 'Un démarrage sur un chantier ciblé',
    duration: 'Périmètre défini en amont',
    description:
      'On commence par quelque chose de délimité — une feature, un refacto, une migration. Vous voyez comment je travaille dans votre contexte. Compte-rendu quotidien dès le premier jour.',
  },
  {
    title: 'La continuité en régie',
    duration: TJM_DISPLAY,
    description:
      "Si la collaboration est satisfaisante des deux côtés, on continue. Je reste dans votre équipe le temps qu'il faut, avec la même rigueur opérationnelle.",
  },
];

const faqs = [
  {
    question: "Comment tu t'intègres dans une codebase existante ?",
    answer:
      "Je lis avant d'écrire. Je commence par comprendre les conventions du projet, les patterns déjà en place, les endroits fragiles. Je ne refactore pas tout dès la première semaine. Si je vois quelque chose qui mérite d'être discuté, je le pose à l'écrit — dans le compte-rendu ou directement dans la PR — sans imposer.",
  },
  {
    question: 'Tu peux prendre un chantier sans brief exhaustif ?',
    answer:
      'Oui, à condition que le scope soit délimité. Je ne travaille pas bien dans le flou total — pas parce que je ne suis pas autonome, mais parce que le flou produit du code qui part dans tous les sens. Si le brief est incomplet, je pose les questions qui manquent avant de démarrer, pas au milieu.',
  },
  {
    question: "Qu'est-ce que tu ne feras pas ?",
    answer:
      "Je ne joue pas au héros. Je ne prends pas de décisions d'architecture qui engagent le long terme sans vous en parler. Je ne code pas vite pour avoir l'air productif — je code proprement pour que ça tienne.",
  },
  {
    question: 'Tu peux coordonner une équipe, pas seulement coder ?',
    answer:
      "Oui. Chez Coton, j'ai piloté des équipes de freelances sur des missions clients — sélection des profils, répartition du travail, points de synchronisation, tests techniques de recrutement. Sur le projet <a href=\"/projets/ublo\" class=\"underline underline-offset-2 hover:text-[var(--color-text)]\">Ublo</a>, j'ai coordonné une équipe de 4 développeurs juniors : cadrage des chantiers, revues de PR, accompagnement technique quotidien. Si vous avez besoin de quelqu'un qui code et structure le travail autour d'une équipe réduite, c'est quelque chose que je fais.",
  },
];
---

<SiteLayout
  title="Renfort senior pour CTO et équipes tech"
  description="Vous avez une équipe tech. Vous cherchez un renfort senior TypeScript qui s'intègre sans friction, travaille avec autonomie, et rend compte chaque jour. Premier échange gratuit en 30 à 45 minutes."
  canonicalPath="/cto-renfort"
>
  <!-- HERO -->
  <section class="pt-16 pb-[var(--space-section-tight)] md:pt-24">
    <Container size="wide">
      <Reveal>
        <p class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-primary-600)]">
          Pour les CTO, leads et chefs de projet
        </p>
        <h1
          class="mt-5 max-w-[24ch] text-[length:var(--text-display)] font-semibold leading-[0.98] tracking-[-0.03em] text-[var(--color-text)]"
        >
          Vous avez besoin de renfort.
          <span class="block text-[var(--color-primary-700)]"
            >Ni junior à former, ni agence à gérer.</span
          >
        </h1>
        <p
          class="mt-10 max-w-[55ch] text-[length:var(--text-xl)] leading-[var(--leading-snug)] text-[var(--color-text-muted)] tracking-[-0.005em]"
        >
          Vous avez un chantier qui déborde, une feature qui traîne, un refacto qui attend. Vous
          cherchez quelqu'un qui lit la codebase, s'intègre à votre équipe, et livre — <strong
            >sans que vous ayez à passer vos journées à relire ou à débloquer.</strong
          >
        </p>
        <div class="mt-12 flex flex-wrap items-center gap-x-6 gap-y-4">
          <PrimaryCta size="lg" class="w-full sm:w-auto" />
          <a
            href="/methode"
            class="group inline-flex items-center gap-2 text-base font-medium text-[var(--color-text)] tracking-[-0.005em]"
          >
            Voir ma méthode
            <span
              class="inline-block h-px w-8 bg-[var(--color-text-subtle)] transition-[width,background-color] duration-[var(--duration-default)] [transition-timing-function:var(--ease-out-quart)] group-hover:w-12 group-hover:bg-[var(--color-primary-600)]"
            ></span>
          </a>
        </div>
      </Reveal>
    </Container>
  </section>

  <!-- BÉNÉFICES -->
  <section
    class="mt-[var(--space-section-tight)] py-[var(--space-section)] border-y border-[var(--color-border)] bg-[var(--color-bg-elevated)]"
  >
    <Container size="wide">
      <Reveal class="max-w-[52ch]">
        <p class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-primary-600)]">
          01 · Ce que vous obtenez
        </p>
        <h2
          class="mt-5 text-[length:var(--text-3xl)] font-semibold leading-[var(--leading-tight)] tracking-[-0.02em] text-[var(--color-text)]"
        >
          Quatre engagements concrets, pas des adjectifs.
        </h2>
      </Reveal>

      <dl class="mt-16 grid items-start gap-x-12 gap-y-12 md:grid-cols-2">
        {
          benefits.map((benefit, index) => (
            <Reveal as="div" delay={index * 70} class="flex flex-col gap-3">
              <dt class="flex items-baseline gap-3">
                <span class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-text-subtle)]">
                  {String(index + 1).padStart(2, '0')}
                </span>
                <span class="h-px flex-1 bg-[var(--color-border)]" aria-hidden="true" />
              </dt>
              <dd>
                <p class="text-[length:var(--text-xl)] font-semibold leading-[var(--leading-snug)] tracking-[-0.015em] text-[var(--color-text)]">
                  {benefit.title}
                </p>
                <p class="mt-3 max-w-[55ch] text-[length:var(--text-base)] leading-[var(--leading-relaxed)] text-[var(--color-text-muted)]">
                  {benefit.description}
                </p>
              </dd>
            </Reveal>
          ))
        }
      </dl>
    </Container>
  </section>

  <!-- DÉROULÉ -->
  <section class="py-[var(--space-section)]">
    <Container size="wide">
      <Reveal class="max-w-[52ch]">
        <p class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-primary-600)]">
          02 · Comment ça se passe
        </p>
        <h2
          class="mt-5 text-[length:var(--text-3xl)] font-semibold leading-[var(--leading-tight)] tracking-[-0.02em] text-[var(--color-text)]"
        >
          Un démarrage ciblé, une continuité en régie.
        </h2>
      </Reveal>

      <ol class="mt-16 border-b border-[var(--color-border)]">
        {
          journey.map((step, index) => (
            <Reveal as="li" delay={index * 80}>
              <article class="flex flex-col gap-6 border-t border-[var(--color-border)] py-10 md:flex-row md:items-start md:gap-12 md:py-12">
                <div class="md:w-72 md:shrink-0">
                  <p class="font-mono text-5xl font-semibold leading-none tracking-[-0.04em] text-[var(--color-primary-700)] md:text-6xl">
                    {String(index + 1).padStart(2, '0')}
                  </p>
                  <p class="mt-4 font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-text-subtle)]">
                    {step.duration}
                  </p>
                </div>
                <div class="md:min-w-0 md:flex-1">
                  <h3 class="text-[length:var(--text-2xl)] font-semibold leading-[var(--leading-snug)] tracking-[-0.015em] text-[var(--color-text)]">
                    {step.title}
                  </h3>
                  <p class="mt-4 max-w-[65ch] text-[length:var(--text-base)] leading-[var(--leading-relaxed)] text-[var(--color-text-muted)]">
                    {step.description}
                  </p>
                </div>
              </article>
            </Reveal>
          ))
        }
      </ol>

      <Reveal class="mt-12">
        <a
          href="/methode"
          class="group inline-flex items-center gap-2 text-base font-medium text-[var(--color-text)] tracking-[-0.005em]"
        >
          Voir tous les détails de la méthode
          <span
            class="inline-block h-px w-8 bg-[var(--color-text-subtle)] transition-[width,background-color] duration-[var(--duration-default)] [transition-timing-function:var(--ease-out-quart)] group-hover:w-12 group-hover:bg-[var(--color-primary-600)]"
          ></span>
        </a>
      </Reveal>
    </Container>
  </section>

  <!-- FAQ COURTE -->
  <section
    class="py-[var(--space-section)] border-y border-[var(--color-border)] bg-[var(--color-bg-subtle)]"
  >
    <Container size="wide">
      <Reveal class="max-w-[52ch]">
        <p class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-primary-600)]">
          03 · Questions qui reviennent
        </p>
        <h2
          class="mt-5 text-[length:var(--text-3xl)] font-semibold leading-[var(--leading-tight)] tracking-[-0.02em] text-[var(--color-text)]"
        >
          Quatre questions qu'on me pose souvent.
        </h2>
      </Reveal>

      <div
        class="mt-16 divide-y divide-[var(--color-border)] border-y border-[var(--color-border)]"
      >
        {
          faqs.map((faq, index) => (
            <Reveal as="div" delay={index * 80}>
              <details class="faq-item group py-8 md:py-10">
                <summary class="faq-summary flex cursor-pointer items-start justify-between gap-6 list-none">
                  <h3 class="text-[length:var(--text-xl)] font-semibold leading-[var(--leading-snug)] tracking-[-0.01em] text-[var(--color-text)]">
                    {faq.question}
                  </h3>
                  <span
                    class="faq-icon mt-1 flex size-7 shrink-0 items-center justify-center rounded-full border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text-subtle)] transition-[transform,background-color,border-color,color] duration-[var(--duration-default)] [transition-timing-function:var(--ease-out-quart)]"
                    aria-hidden="true"
                  >
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                      <path
                        d="M6 2v8M2 6h8"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                      />
                    </svg>
                  </span>
                </summary>
                <p
                  class="mt-5 max-w-[95ch] text-[length:var(--text-base)] leading-[var(--leading-relaxed)] text-[var(--color-text-muted)]"
                  set:html={faq.answer}
                />
              </details>
            </Reveal>
          ))
        }
      </div>

      <Reveal class="mt-12">
        <a
          href="/faq"
          class="group inline-flex items-center gap-2 text-base font-medium text-[var(--color-text)] tracking-[-0.005em]"
        >
          Voir toutes les questions fréquentes
          <span
            class="inline-block h-px w-8 bg-[var(--color-text-subtle)] transition-[width,background-color] duration-[var(--duration-default)] [transition-timing-function:var(--ease-out-quart)] group-hover:w-12 group-hover:bg-[var(--color-primary-600)]"
          ></span>
        </a>
      </Reveal>
    </Container>
  </section>

  <!-- CTA FINALE -->
  <section
    class="relative overflow-hidden py-[var(--space-section)] bg-[var(--color-bg-deep)] text-[var(--color-text-inverse)]"
  >
    <div
      aria-hidden="true"
      class="pointer-events-none absolute -top-32 -right-32 size-[28rem] rounded-full opacity-30"
      style="background: radial-gradient(closest-side, oklch(50% 0.12 155 / 0.6), transparent);"
    >
    </div>

    <Container size="wide">
      <div class="grid gap-12 lg:grid-cols-12 lg:items-end">
        <Reveal class="lg:col-span-8">
          <p class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-primary-200)]">
            Premier échange · {RDV_DURATION_LABEL} · Sans engagement
          </p>
          <h2
            class="mt-5 text-[length:var(--text-5xl)] font-semibold leading-[0.98] tracking-[-0.03em]"
          >
            On parle du chantier,
            <span class="block text-[var(--color-primary-200)]">concrètement.</span>
          </h2>
          <p
            class="mt-8 max-w-[55ch] text-[length:var(--text-lg)] leading-[var(--leading-relaxed)] text-[color-mix(in_oklab,var(--color-text-inverse)_75%,transparent)]"
          >
            Vous décrivez le contexte, la stack, ce qui bloque. Je vous dis si je suis le bon
            profil, et comment ça pourrait se passer. Trente minutes, sans engagement.
          </p>
        </Reveal>
        <Reveal class="lg:col-span-4 lg:text-right" delay={150}>
          <PrimaryCta size="lg" class="w-full sm:w-auto" />
        </Reveal>
      </div>
    </Container>
  </section>
</SiteLayout>

<style>
  .faq-summary::-webkit-details-marker {
    display: none;
  }

  .faq-item[open] .faq-icon {
    transform: rotate(45deg);
    border-color: var(--color-primary-400);
    background: var(--color-primary-50);
    color: var(--color-primary-700);
  }

  .faq-summary:hover .faq-icon {
    border-color: var(--color-primary-400);
    color: var(--color-primary-700);
  }
</style>
