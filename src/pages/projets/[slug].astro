---
import SiteLayout from '../../layouts/SiteLayout.astro';
import Container from '../../components/layout/Container.astro';
import PrimaryCta from '../../components/ui/PrimaryCta.astro';
import Reveal from '../../components/ui/Reveal.astro';
import { PROJETS } from '../../lib/projets.const';

export async function getStaticPaths() {
  const paths = await Promise.all(
    PROJETS.map(async (projet) => {
      let screenshotUrl: string | null = null;
      if (projet.url) {
        try {
          const resp = await fetch(
            `https://api.microlink.io/?url=${encodeURIComponent(projet.url)}&screenshot=true`
          );
          if (resp.ok) {
            const json = await resp.json();
            screenshotUrl = (json?.data?.screenshot?.url as string) ?? null;
          }
        } catch {
          // screenshot indisponible
        }
      }
      return {
        params: { slug: projet.slug },
        props: { projet, screenshotUrl },
      };
    })
  );
  return paths;
}

const { projet, screenshotUrl } = Astro.props;
const index = PROJETS.findIndex((p) => p.slug === projet.slug);
const prev = index > 0 ? PROJETS[index - 1] : null;
const next = index < PROJETS.length - 1 ? PROJETS[index + 1] : null;

const siteHostname = projet.url ? new URL(projet.url).hostname.replace('www.', '') : null;
---

<SiteLayout
  title={projet.titre}
  description={projet.resume}
  canonicalPath={`/projets/${projet.slug}`}
>
  <!-- HERO -->
  <section class="pt-16 pb-[var(--space-section-tight)] md:pt-24">
    <Container size="wide">
      <Reveal>
        <a
          href="/projets"
          class="group inline-flex items-center gap-2 font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-text-subtle)] hover:text-[var(--color-primary-700)] transition-colors duration-[var(--duration-fast)]"
        >
          <svg
            aria-hidden="true"
            width="12"
            height="12"
            viewBox="0 0 14 14"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="transition-transform duration-[var(--duration-fast)] group-hover:-translate-x-0.5"
          >
            <path d="M11.5 7h-9" />
            <path d="M6 3.5 2.5 7 6 10.5" />
          </svg>
          Tous les projets
        </a>
      </Reveal>

      <div class="mt-8 grid gap-12 lg:grid-cols-12 lg:items-start lg:gap-16">
        <!-- Colonne gauche : texte -->
        <Reveal class="lg:col-span-7">
          <p class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-primary-600)]">
            {projet.secteur} · {projet.periode}
          </p>
          <h1
            class="mt-5 max-w-[28ch] text-[length:var(--text-display)] font-semibold leading-[0.98] tracking-[-0.03em] text-[var(--color-text)]"
          >
            {projet.titre}
          </h1>
          <p
            class="mt-8 max-w-[55ch] text-[length:var(--text-xl)] leading-[var(--leading-snug)] text-[var(--color-text-muted)] tracking-[-0.005em]"
          >
            {projet.resume}
          </p>
        </Reveal>

        <!-- Colonne droite : card aperçu site -->
        <Reveal class="lg:col-span-5" delay={100}>
          {projet.url ? (
            <a
              href={projet.url}
              target="_blank"
              rel="noopener noreferrer"
              class="site-card group block overflow-hidden rounded-[var(--radius-lg)] border border-[var(--color-border)] transition-[box-shadow,border-color] duration-[var(--duration-default)] hover:border-[var(--color-primary-300)] hover:shadow-md"
            >
              <!-- Zone screenshot -->
              <div class="relative aspect-video bg-[var(--color-bg-subtle)]" style="display:grid">
                <div
                  class="flex items-center justify-center"
                  style="grid-area:1/1"
                  aria-hidden="true"
                >
                  <span class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-text-subtle)]">
                    {siteHostname}
                  </span>
                </div>
                <img
                  src={screenshotUrl}
                  alt={`Aperçu de ${siteHostname}`}
                  loading="lazy"
                  decoding="async"
                  style="grid-area:1/1; width:100%; height:100%; object-fit:cover; object-position:top center"
                  onerror="this.style.display='none'"
                />
              </div>
              <!-- Footer bar -->
              <div class="flex items-center gap-2.5 border-t border-[var(--color-border)] bg-[var(--color-bg-elevated)] px-4 py-3">
                <img
                  src={`https://www.google.com/s2/favicons?sz=32&domain=${siteHostname}`}
                  alt=""
                  aria-hidden="true"
                  width="16"
                  height="16"
                  class="size-4 shrink-0"
                  onerror="this.style.display='none'"
                />
                <span class="flex-1 truncate font-mono text-xs text-[var(--color-text-muted)]">
                  {siteHostname}
                </span>
                <svg
                  aria-hidden="true"
                  width="12"
                  height="12"
                  viewBox="0 0 14 14"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="shrink-0 text-[var(--color-text-subtle)] transition-transform duration-[var(--duration-fast)] group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                >
                  <path d="M5 3h6v6" />
                  <path d="M11 3 4 10" />
                </svg>
              </div>
            </a>
          ) : (
            <div class="overflow-hidden rounded-[var(--radius-lg)] border border-dashed border-[var(--color-border)]">
              <div class="flex aspect-video items-center justify-center bg-[var(--color-bg-subtle)]">
                <p class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-text-subtle)]">
                  Site non public
                </p>
              </div>
              <div class="border-t border-[var(--color-border)] bg-[var(--color-bg-elevated)] px-4 py-3">
                <p class="font-mono text-xs text-[var(--color-text-subtle)]">Accès client restreint</p>
              </div>
            </div>
          )}
        </Reveal>
      </div>
    </Container>
  </section>

  <!-- SCHÉMA ARCHITECTURE -->
  <section
    class="mt-[var(--space-section-tight)] py-[var(--space-section)] border-y border-[var(--color-border)] bg-[var(--color-bg-elevated)]"
  >
    <Container size="wide">
      <Reveal>
        <p class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-primary-600)]">
          Architecture
        </p>
        <h2
          class="mt-5 text-[length:var(--text-2xl)] font-semibold leading-[var(--leading-tight)] tracking-[-0.02em] text-[var(--color-text)]"
        >
          Vue d'ensemble technique
        </h2>
      </Reveal>

      <Reveal class="mt-10" delay={80}>
        <div
          class="overflow-x-auto rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-bg)] p-8"
        >
          <Fragment set:html={projet.schema} />
        </div>
        <p class="mt-3 font-mono text-xs text-[var(--color-text-subtle)] italic">
          Schéma à remplacer par l'export Excalidraw du projet réel.
        </p>
      </Reveal>
    </Container>
  </section>

  <!-- CONTEXTE + LIVRABLES -->
  <section class="py-[var(--space-section)]">
    <Container size="wide">
      <div class="grid gap-16 lg:grid-cols-12 lg:gap-x-20">
        <!-- Contexte -->
        <Reveal class="lg:col-span-5">
          <p class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-primary-600)]">
            Contexte
          </p>
          <p
            class="mt-6 text-[length:var(--text-lg)] leading-[var(--leading-relaxed)] text-[var(--color-text-muted)]"
          >
            {projet.contexte}
          </p>

          <div class="mt-10">
            <p class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-text-subtle)]">
              Stack
            </p>
            <ul class="mt-4 flex flex-wrap gap-2">
              {
                projet.stack.map((tag) => (
                  <li class="rounded-[var(--radius-pill)] border border-[var(--color-border)] bg-[var(--color-bg-elevated)] px-3 py-1.5 font-mono text-xs text-[var(--color-text)]">
                    {tag}
                  </li>
                ))
              }
            </ul>
          </div>
        </Reveal>

        <!-- Livrables -->
        <Reveal class="lg:col-span-7" delay={100}>
          <p class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-primary-600)]">
            Livrables
          </p>
          <ul class="mt-6 space-y-4">
            {
              projet.livrables.map((livrable) => (
                <li class="flex items-center gap-4">
                  <span
                    class="size-1.5 shrink-0 rounded-full bg-[var(--color-primary-500)]"
                    aria-hidden="true"
                  />
                  <span class="text-[length:var(--text-base)] leading-[var(--leading-relaxed)] text-[var(--color-text-muted)]">
                    {livrable}
                  </span>
                </li>
              ))
            }
          </ul>
        </Reveal>
      </div>
    </Container>
  </section>

  <!-- NAVIGATION ENTRE PROJETS -->
  {
    (prev || next) && (
      <section class="border-t border-[var(--color-border)] py-12">
        <Container size="wide">
          <div class="flex items-center justify-between gap-8">
            {prev ? (
              <a
                href={`/projets/${prev.slug}`}
                class="group flex flex-col gap-1"
              >
                <span class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-text-subtle)]">
                  ← Précédent
                </span>
                <span class="text-[length:var(--text-base)] font-medium text-[var(--color-text)] group-hover:text-[var(--color-primary-700)] transition-colors duration-[var(--duration-fast)]">
                  {prev.titre}
                </span>
              </a>
            ) : (
              <span />
            )}
            {next && (
              <a
                href={`/projets/${next.slug}`}
                class="group flex flex-col items-end gap-1"
              >
                <span class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-text-subtle)]">
                  Suivant →
                </span>
                <span class="text-[length:var(--text-base)] font-medium text-[var(--color-text)] group-hover:text-[var(--color-primary-700)] transition-colors duration-[var(--duration-fast)]">
                  {next.titre}
                </span>
              </a>
            )}
          </div>
        </Container>
      </section>
    )
  }

  <!-- CTA FINALE -->
  <section
    class="relative overflow-hidden py-[var(--space-section)] bg-[var(--color-bg-deep)] text-[var(--color-text-inverse)]"
  >
    <div
      aria-hidden="true"
      class="pointer-events-none absolute -top-32 -right-32 size-[28rem] rounded-full opacity-30"
      style="background: radial-gradient(closest-side, oklch(50% 0.12 155 / 0.6), transparent);"
    >
    </div>
    <Container size="wide">
      <div class="grid gap-12 lg:grid-cols-12 lg:items-end">
        <Reveal class="lg:col-span-8">
          <p class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-primary-200)]">
            Vous avez un projet similaire ?
          </p>
          <h2
            class="mt-5 text-[length:var(--text-5xl)] font-semibold leading-[0.98] tracking-[-0.03em]"
          >
            On en parle,
            <span class="block text-[var(--color-primary-200)]">sans engagement.</span>
          </h2>
        </Reveal>
        <Reveal class="lg:col-span-4 lg:text-right" delay={150}>
          <PrimaryCta size="lg" class="w-full sm:w-auto" />
        </Reveal>
      </div>
    </Container>
  </section>
</SiteLayout>
