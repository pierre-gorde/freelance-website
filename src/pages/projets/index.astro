---
import SiteLayout from '../../layouts/SiteLayout.astro';
import Container from '../../components/layout/Container.astro';
import PrimaryCta from '../../components/ui/PrimaryCta.astro';
import Reveal from '../../components/ui/Reveal.astro';
import { PROJETS } from '../../lib/projets.const';
---

<SiteLayout
  title="Projets"
  description="Sélection de projets clients — plateformes B2B, refontes API, dashboards, pipelines d'intégration. TypeScript, frontend et backend."
  canonicalPath="/projets"
>
  <!-- HERO -->
  <section class="pt-16 pb-[var(--space-section-tight)] md:pt-24">
    <Container size="wide">
      <Reveal>
        <p class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-primary-600)]">
          Projets
        </p>
        <h1
          class="mt-5 max-w-[22ch] text-[length:var(--text-display)] font-semibold leading-[0.98] tracking-[-0.03em] text-[var(--color-text)]"
        >
          Ce sur quoi j'ai travaillé.
        </h1>
        <p
          class="mt-8 max-w-[52ch] text-[length:var(--text-xl)] leading-[var(--leading-snug)] text-[var(--color-text-muted)] tracking-[-0.005em]"
        >
          Sélection de missions clients — contextes variés, stack TypeScript, livrables concrets.
        </p>
      </Reveal>
    </Container>
  </section>

  <!-- LISTE DES PROJETS -->
  <section class="py-[var(--space-section)]">
    <Container size="wide">
      <ul class="divide-y divide-[var(--color-border)] border-y border-[var(--color-border)]">
        {
          PROJETS.map((projet, index) => (
            <Reveal as="li" delay={index * 60}>
              <a
                href={`/projets/${projet.slug}`}
                class="projet-row group flex flex-col gap-6 py-10 md:flex-row md:items-start md:gap-12 md:py-12"
              >
                <div class="flex shrink-0 items-baseline gap-4 md:w-48 md:flex-col md:gap-2">
                  <span class="font-mono text-3xl font-semibold leading-none tracking-[-0.04em] text-[var(--color-text-subtle)] transition-colors duration-[var(--duration-default)] group-hover:text-[var(--color-primary-600)] md:text-5xl">
                    {String(index + 1).padStart(2, '0')}
                  </span>
                  <span class="font-mono text-xs uppercase tracking-[0.12em] text-[var(--color-text-subtle)]">
                    {projet.secteur}
                  </span>
                </div>

                <div class="flex-1">
                  <p class="text-[length:var(--text-xl)] font-semibold leading-[var(--leading-snug)] tracking-[-0.015em] text-[var(--color-text)]">
                    {projet.titre}
                  </p>
                  <p class="mt-3 max-w-[60ch] text-[length:var(--text-base)] leading-[var(--leading-relaxed)] text-[var(--color-text-muted)]">
                    {projet.resume}
                  </p>
                  <ul class="mt-5 flex flex-wrap gap-2">
                    {projet.stack.map((tag) => (
                      <li class="rounded-[var(--radius-pill)] border border-[var(--color-border)] bg-[var(--color-bg-elevated)] px-3 py-1 font-mono text-xs text-[var(--color-text-subtle)]">
                        {tag}
                      </li>
                    ))}
                  </ul>
                </div>

                <div class="projet-arrow flex shrink-0 flex-col items-end gap-2 md:self-center">
                  <span class="font-mono text-xs text-[var(--color-text-subtle)]">{projet.periode}</span>
                  <span class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--color-primary-700)]">
                    Voir le projet
                    <svg
                      aria-hidden="true"
                      width="14"
                      height="14"
                      viewBox="0 0 14 14"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M2.5 7h9" />
                      <path d="M8 3.5 11.5 7 8 10.5" />
                    </svg>
                  </span>
                </div>
              </a>
            </Reveal>
          ))
        }
      </ul>
    </Container>
  </section>

  <!-- CTA FINALE -->
  <section
    class="relative overflow-hidden py-[var(--space-section)] bg-[var(--color-bg-deep)] text-[var(--color-text-inverse)]"
  >
    <div
      aria-hidden="true"
      class="pointer-events-none absolute -top-32 -right-32 size-[28rem] rounded-full opacity-30"
      style="background: radial-gradient(closest-side, oklch(50% 0.12 155 / 0.6), transparent);"
    >
    </div>
    <Container size="wide">
      <div class="grid gap-12 lg:grid-cols-12 lg:items-end">
        <Reveal class="lg:col-span-8">
          <p class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--color-primary-200)]">
            Votre projet
          </p>
          <h2
            class="mt-5 text-[length:var(--text-5xl)] font-semibold leading-[0.98] tracking-[-0.03em]"
          >
            Le vôtre pourrait
            <span class="block text-[var(--color-primary-200)]">être ici.</span>
          </h2>
        </Reveal>
        <Reveal class="lg:col-span-4 lg:text-right" delay={150}>
          <PrimaryCta size="lg" class="w-full sm:w-auto" />
        </Reveal>
      </div>
    </Container>
  </section>
</SiteLayout>

<style>
  .projet-row {
    transition: padding-left 0.35s var(--ease-out-quart);
  }
  .projet-row:hover {
    padding-left: 0.5rem;
  }
  .projet-arrow svg {
    transition: transform 0.3s var(--ease-out-quart);
  }
  .projet-row:hover .projet-arrow svg {
    transform: translateX(4px);
  }
</style>
