---
// Texture SVG ultra-subtile pour donner de la profondeur au hero
// sans crier. Inspiration : Mercury, Anthropic.
---

<svg
  class="absolute inset-0 -z-10 size-full text-[var(--color-primary-700)]"
  aria-hidden="true"
  xmlns="http://www.w3.org/2000/svg"
>
  <defs>
    <pattern id="hero-grid" width="60" height="60" patternUnits="userSpaceOnUse">
      <path d="M 60 0 L 0 0 0 60" fill="none" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.05" />
    </pattern>
    <radialGradient id="hero-fade" cx="0" cy="0" r="1" gradientUnits="userSpaceOnUse"
      gradientTransform="translate(120 80) rotate(45) scale(800 500)">
      <stop offset="0" stop-color="white" stop-opacity="1" />
      <stop offset="1" stop-color="white" stop-opacity="0" />
    </radialGradient>
    <mask id="hero-mask">
      <rect width="100%" height="100%" fill="url(#hero-fade)" />
    </mask>
  </defs>
  <rect width="100%" height="100%" fill="url(#hero-grid)" mask="url(#hero-mask)" />
</svg>
