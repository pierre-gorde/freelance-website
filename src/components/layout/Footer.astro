---
import { PERSONA_LINKS, PRIMARY_NAV_LINKS } from '../../lib/links.const';
import { CONTACT_EMAIL, GITHUB_URL, LINKEDIN_URL, SITE_NAME } from '../../lib/site.const';

const currentYear = '2026';
---

<footer
  class="mt-[var(--space-section)] border-t border-[var(--color-border)] bg-[var(--color-bg-subtle)]"
>
  <div class="mx-auto max-w-[var(--container-wide)] px-6 sm:px-8 lg:px-12 py-16">
    <div class="grid gap-12 md:grid-cols-12">
      <div class="md:col-span-5">
        <p class="font-semibold text-[var(--color-text)] text-lg tracking-[-0.015em]">
          {SITE_NAME}
        </p>
        <p class="mt-3 max-w-md text-[var(--color-text-muted)] leading-[var(--leading-relaxed)]">
          Je conçois et je livre vos produits tech, avec un point quotidien sur l'avancée.
        </p>
        <a
          href={`mailto:${CONTACT_EMAIL}`}
          class="mt-6 inline-block text-[var(--color-text)] hover:text-[var(--color-primary-700)] transition-colors duration-[var(--duration-fast)]"
        >
          {CONTACT_EMAIL}
        </a>
      </div>

      <nav aria-label="Navigation pied de page" class="md:col-span-3">
        <p
          class="mb-4 text-xs font-medium uppercase tracking-[0.1em] text-[var(--color-text-subtle)]"
        >
          Navigation
        </p>
        <ul class="space-y-2.5">
          {
            PRIMARY_NAV_LINKS.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-[var(--color-text-muted)] hover:text-[var(--color-primary-700)] transition-colors duration-[var(--duration-fast)]"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="md:col-span-2">
        <p
          class="mb-4 text-xs font-medium uppercase tracking-[0.1em] text-[var(--color-text-subtle)]"
        >
          Vous êtes
        </p>
        <ul class="space-y-2.5">
          {
            PERSONA_LINKS.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-[var(--color-text-muted)] hover:text-[var(--color-primary-700)] transition-colors duration-[var(--duration-fast)]"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="md:col-span-2">
        <p
          class="mb-4 text-xs font-medium uppercase tracking-[0.1em] text-[var(--color-text-subtle)]"
        >
          Ailleurs
        </p>
        <ul class="space-y-2.5">
          <li>
            <a
              href={LINKEDIN_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="text-[var(--color-text-muted)] hover:text-[var(--color-primary-700)] transition-colors duration-[var(--duration-fast)]"
            >
              LinkedIn
            </a>
          </li>
          <li>
            <a
              href={GITHUB_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="text-[var(--color-text-muted)] hover:text-[var(--color-primary-700)] transition-colors duration-[var(--duration-fast)]"
            >
              GitHub
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div
      class="mt-16 flex flex-col gap-4 border-t border-[var(--color-border)] pt-8 text-sm text-[var(--color-text-subtle)] sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {currentYear} {SITE_NAME}. Tous droits réservés.</p>
      <a
        href="/mentions-legales"
        class="hover:text-[var(--color-text)] transition-colors duration-[var(--duration-fast)]"
      >
        Mentions légales
      </a>
    </div>
  </div>
</footer>
