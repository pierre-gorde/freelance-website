---
import PrimaryCta from '../ui/PrimaryCta.astro';
import { PRIMARY_NAV_LINKS } from '../../lib/links.const';
import { SITE_NAME } from '../../lib/site.const';

const currentPath = Astro.url.pathname;
const isActive = (href: string): boolean =>
  currentPath === href || currentPath.startsWith(`${href}/`);
---

<header
  class="sticky top-0 z-40 border-b border-[var(--color-border)] bg-[color-mix(in_oklab,var(--color-bg)_85%,transparent)] backdrop-blur-md"
>
  <div class="mx-auto flex h-16 max-w-[var(--container-wide)] items-center justify-between gap-6 px-6 sm:px-8 lg:px-12">
    <a
      href="/"
      class="font-semibold tracking-[-0.015em] text-[var(--color-text)] hover:text-[var(--color-primary-700)] transition-colors duration-[var(--duration-fast)]"
      aria-label={`${SITE_NAME} — accueil`}
    >
      {SITE_NAME}
    </a>

    <nav aria-label="Navigation principale" class="hidden md:block">
      <ul class="flex items-center gap-1">
        {
          PRIMARY_NAV_LINKS.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  'inline-flex h-10 items-center rounded-[var(--radius-md)] px-3 text-sm font-medium transition-colors duration-[var(--duration-fast)]',
                  isActive(link.href)
                    ? 'text-[var(--color-primary-700)] bg-[var(--color-primary-50)]'
                    : 'text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-bg-subtle)]',
                ]}
                aria-current={isActive(link.href) ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <PrimaryCta size="sm" label="Échange gratuit" />
  </div>
</header>
