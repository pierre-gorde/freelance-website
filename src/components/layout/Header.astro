---
import PrimaryCta from '../ui/PrimaryCta.astro';
import { PRIMARY_NAV_LINKS } from '../../lib/links.const';
import { SITE_NAME } from '../../lib/site.const';

const currentPath = Astro.url.pathname;
const isActive = (href: string): boolean =>
  currentPath === href || currentPath.startsWith(`${href}/`);
---

<header
  class="sticky top-0 z-40 border-b border-[var(--color-border)] bg-[color-mix(in_oklab,var(--color-bg)_85%,transparent)] backdrop-blur-md"
>
  <div
    class="mx-auto flex h-16 max-w-[var(--container-wide)] items-center justify-between gap-4 px-6 sm:px-8 lg:px-12"
  >
    <a
      href="/"
      class="inline-flex items-center gap-2.5 font-semibold tracking-[-0.015em] text-[var(--color-text)] hover:text-[var(--color-primary-700)] transition-colors duration-[var(--duration-fast)]"
      aria-label={`${SITE_NAME} — accueil`}
    >
      <img
        src="/illustrations/pierre-01.png"
        alt=""
        aria-hidden="true"
        width="28"
        height="28"
        class="size-10 rounded-full object-cover object-top"
        loading="eager"
        decoding="async"
      />
      {SITE_NAME}
    </a>

    <nav aria-label="Navigation principale" class="hidden md:block">
      <ul class="flex items-center gap-1">
        {
          PRIMARY_NAV_LINKS.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  'inline-flex h-10 items-center rounded-[var(--radius-md)] px-3 text-sm font-medium transition-colors duration-[var(--duration-fast)]',
                  isActive(link.href)
                    ? 'text-[var(--color-primary-700)] bg-[var(--color-primary-50)]'
                    : 'text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-bg-subtle)]',
                ]}
                aria-current={isActive(link.href) ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex items-center gap-2">
      <PrimaryCta size="sm" label="Échange gratuit" />

      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="Ouvrir le menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="md:hidden inline-flex h-9 w-9 items-center justify-center rounded-md text-text-muted hover:text-text hover:bg-bg-subtle transition-colors duration-(--duration-fast)"
      >
        <svg
          id="icon-burger"
          aria-hidden="true"
          width="18"
          height="18"
          viewBox="0 0 18 18"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
        >
          <line x1="2" y1="5" x2="16" y2="5"></line>
          <line x1="2" y1="9" x2="16" y2="9"></line>
          <line x1="2" y1="13" x2="16" y2="13"></line>
        </svg>
        <svg
          id="icon-close"
          aria-hidden="true"
          width="18"
          height="18"
          viewBox="0 0 18 18"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          class="hidden"
        >
          <line x1="3" y1="3" x2="15" y2="15"></line>
          <line x1="15" y1="3" x2="3" y2="15"></line>
        </svg>
      </button>
    </div>
  </div>
</header>

<div id="mobile-backdrop" class="mobile-backdrop md:hidden hidden" aria-hidden="true"></div>

<nav id="mobile-menu" aria-label="Navigation mobile" class="mobile-menu-drawer md:hidden hidden">
  <ul class="mx-auto max-w-wide flex flex-col divide-y divide-border px-6 sm:px-8">
    {
      PRIMARY_NAV_LINKS.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'flex items-center justify-between py-4 text-base font-medium transition-colors duration-(--duration-fast)',
              isActive(link.href) ? 'text-primary-700' : 'text-text-muted hover:text-text',
            ]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
            <svg
              aria-hidden="true"
              width="14"
              height="14"
              viewBox="0 0 14 14"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="opacity-40"
            >
              <path d="M2.5 7h9" />
              <path d="M8 3.5 11.5 7 8 10.5" />
            </svg>
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .mobile-backdrop {
    position: fixed;
    inset: 0;
    z-index: 38; /* sous le drawer (39) et le header (40) */
    background: oklch(1 0 0 / 0.4);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .mobile-backdrop:not(.hidden) {
    animation: backdrop-in 0.2s var(--ease-out-quart) both;
  }

  @keyframes backdrop-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .mobile-menu-drawer {
    position: fixed;
    top: 4rem; /* h-16 — hauteur exacte du header */
    left: 0;
    right: 0;
    z-index: 39; /* sous le header z-40 */
    background: color-mix(in oklab, var(--color-bg) 96%, transparent);
    backdrop-filter: blur(12px);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .mobile-menu-drawer:not(.hidden) {
    animation: drawer-open 0.2s var(--ease-out-quart) both;
  }

  @keyframes drawer-open {
    from {
      opacity: 0;
      transform: translateY(-6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-menu-drawer:not(.hidden) {
      animation: none;
    }
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn') as HTMLButtonElement | null;
  const menu = document.getElementById('mobile-menu');
  const backdrop = document.getElementById('mobile-backdrop');
  const iconBurger = document.getElementById('icon-burger');
  const iconClose = document.getElementById('icon-close');

  function openMenu() {
    menu?.classList.remove('hidden');
    backdrop?.classList.remove('hidden');
    btn?.setAttribute('aria-expanded', 'true');
    iconBurger?.classList.add('hidden');
    iconClose?.classList.remove('hidden');
  }

  function closeMenu() {
    menu?.classList.add('hidden');
    backdrop?.classList.add('hidden');
    btn?.setAttribute('aria-expanded', 'false');
    iconBurger?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
  }

  btn?.addEventListener('click', () => {
    const isOpen = btn.getAttribute('aria-expanded') === 'true';
    isOpen ? closeMenu() : openMenu();
  });

  backdrop?.addEventListener('click', closeMenu);

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });
</script>
